# --- docker-compose (contenedor de PostgreSQL) ---
POSTGRES_DB=energia
POSTGRES_USER=energia
POSTGRES_PASSWORD=changeme
POSTGRES_HOST_PORT=5434

# --- backend (energia.shared.config.Settings) ---
# Host desde el que el backend alcanza la base de datos. "localhost" funciona cuando el
# backend corre en el host y la DB está expuesta vía docker-compose (ver POSTGRES_HOST_PORT
# arriba). Dentro de un contenedor en la misma red de compose, usar el nombre del servicio
# ("db") en su lugar.
POSTGRES_HOST=localhost

# Opcional. Si se define, reemplaza por completo la URL ensamblada a partir de las variables
# POSTGRES_* de arriba. Debe ser una URL async de SQLAlchemy, ej.:
# DATABASE_URL=postgresql+asyncpg://energia:changeme@localhost:5434/energia
